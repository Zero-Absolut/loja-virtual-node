<!DOCTYPE html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Loja</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>

  <body>
    <!-- INFO BAR -->
    <section class="info-bar">
      <div class="container-fluid px-5">
        <div class="row justify-content-between text-center text-md-start">
          <div
            class="col-md-4 d-flex align-items-center gap-2 justify-content-center justify-content-md-start"
          >
            <i class="fa-solid fa-credit-card"></i>
            <p>Parcelamento em até 3x sem juros</p>
          </div>

          <div
            class="col-md-4 d-flex align-items-center gap-2 justify-content-center"
          >
            <i class="fa-solid fa-motorcycle"></i>
            <p>Entregas por Motoboy para o Rio</p>
          </div>

          <div
            class="col-md-4 d-flex align-items-center gap-2 justify-content-center justify-content-md-end"
          >
            <i class="fa-solid fa-truck-fast"></i>
            <p>Frete grátis a partir de R$399</p>
          </div>
        </div>
      </div>
    </section>

    <main class="main-content">
      <!-- CAROUSEL -->
      <section class="carousel-container full-width">
        <div
          id="carouselExample"
          class="carousel slide"
          data-bs-ride="carousel"
        >
          <div class="carousel-inner">
            <div class="carousel-item active">
              <img src="assets/img/img_site/modal1.png" class="d-block w-100" />
              <div class="carousel-caption">
                <h2>Novidades da Estação</h2>
                <p>Descubra os looks que são tendência!</p>
                <a href="#" class="btn-shop-now">Compre Agora</a>
              </div>
            </div>

            <div class="carousel-item">
              <img src="assets/img/img_site/modal3.png" class="d-block w-100" />
              <div class="carousel-caption">
                <h2>Acessórios que Transformam</h2>
                <p>O toque final perfeito para o seu estilo.</p>
                <a href="#" class="btn-shop-now">Explore</a>
              </div>
            </div>

            <div class="carousel-item">
              <img src="assets/img/img_site/modal4.png" class="d-block w-100" />
              <div class="carousel-caption">
                <h2>Óculos com 30% de Desconto</h2>
                <p>Proteção e estilo para todos os momentos.</p>
                <a href="#" class="btn-shop-now">Ver Oferta</a>
              </div>
            </div>
          </div>

          <button
            class="carousel-control-prev"
            type="button"
            data-bs-target="#carouselExample"
            data-bs-slide="prev"
          ></button>
          <button
            class="carousel-control-next"
            type="button"
            data-bs-target="#carouselExample"
            data-bs-slide="next"
          ></button>
        </div>
      </section>

      <!-- CATEGORIAS -->
      <section class="categories-section container-fluid px-5">
        <h2>Compre por Categoria</h2>

        <div class="row g-4">
          <div class="col-6 col-md-3">
            <a href="#" class="category-item">
              <img src="assets/img/img_site/2.png" />
              <h4>Roupas</h4>
            </a>
          </div>

          <div class="col-6 col-md-3">
            <a href="#" class="category-item">
              <img src="assets/img/img_site/2.png" />
              <h4>Acessórios</h4>
            </a>
          </div>

          <div class="col-6 col-md-3">
            <a href="#" class="category-item">
              <img src="assets/img/img_site/2.png" />
              <h4>Óculos</h4>
            </a>
          </div>

          <div class="col-6 col-md-3">
            <a href="#" class="category-item">
              <img src="assets/img/img_site/2.png" />
              <h4>Bolsas</h4>
            </a>
          </div>
        </div>
      </section>

      <!-- PRODUTOS -->
      <section class="featured-products container-fluid px-5">
        <h2>Novidades</h2>

        <div class="row g-4">
          <!-- PRODUTO -->
          <div class="col-6 col-md-4 col-lg-3">
            <div class="product-card">
              <div class="product-image">
                <img src="assets/img/img_site/2.png" class="img-default" />
                <img src="assets/img/img_site/2.png" class="img-hover" />
              </div>

              <div class="product-info">
                <h3>Short Sarja</h3>
                <p class="product-price">R$ 89,90</p>
              </div>

              <a href="#" class="btn-view-product">VER PRODUTO</a>
            </div>
          </div>

          <!-- DUPLICAR EXATAMENTE COMO ORIGINAL -->
          <!-- (mantive estrutura, você só replica os outros produtos aqui) -->
        </div>
      </section>

      <!-- DESCONTOS -->
      <section class="featured-products container-fluid px-5">
        <h2>Descontos Imperdíveis</h2>

        <div class="row g-4">
          <div class="col-6 col-md-4 col-lg-3">
            <div class="product-card">
              <div class="product-image">
                <img src="assets/img/img_site/2.png" class="img-default" />
                <img src="assets/img/img_site/2.png" class="img-hover" />
              </div>

              <div class="product-info">
                <h3>Óculos de Sol</h3>
                <p class="product-price">R$ 150,00</p>
              </div>

              <a href="#" class="btn-view-product">VER PRODUTO</a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
