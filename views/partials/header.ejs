  />

  <!-- FONT AWESOME (ÍCONES) -->
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"
  />

  <!-- GOOGLE FONTS -->
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@200;400&family=Poppins:wght@400;500&display=swap"
